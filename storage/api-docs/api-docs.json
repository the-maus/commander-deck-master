                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The q is required."
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/decks": {
            "get": {
                "tags": [
                    "Decks"
                ],
                "summary": "Lists decks",
                "operationId": "41c4d838083d7fe11a8e52367801bc15",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "The list page",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "A deck list with fewer properties (below) and the pagination data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "Atraxa superfriends"
                                        },
                                        "art_crop": {
                                            "type": "string",
                                            "example": "https://cards.scryfall.io/art_crop/front/1/c/1cc9e7cb-d4f4-4f06-b232-f91eb39fe1b3.jpg?1734853541"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Decks"
                ],
                "summary": "Create a new deck",
                "operationId": "c9f612dcc5d32329f327738b766e4aa8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "commander_name"
                                ],
                                "properties": {
                                    "name": {
                                        "description": "The deck name",
                                        "type": "string",
                                        "example": "Atraxa superfriends"
                                    },
                                    "commander_name": {
                                        "description": "The commander card name",
                                        "type": "string",
                                        "example": "Atraxa, Praetors' Voice"
                                    },
                                    "image_url": {
                                        "description": "URL for the selected commander card print variation image",
                                        "type": "string",
                                        "example": "https://cards.scryfall.io/normal/front/d/0/d0d33d52-3d28-4635-b985-51e126289259.jpg?1599707796"
                                    },
                                    "art_crop": {
                                        "description": "URL for the selected commander card art",
                                        "type": "string",
                                        "example": "https://cards.scryfall.io/art_crop/front/1/c/1cc9e7cb-d4f4-4f06-b232-f91eb39fe1b3.jpg?1734853541"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Deck created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "Atraxa superfriends"
                                        },
                                        "commander_name": {
                                            "type": "string",
                                            "example": "Atraxa, Praetors' Voice"
                                        },
                                        "commander_colors": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            },
                                            "example": "[\"G\", \"W\", \"U\", \"B\"]"
                                        },
                                        "image_url": {
                                            "type": "string",
                                            "example": "https://cards.scryfall.io/normal/front/d/0/d0d33d52-3d28-4635-b985-51e126289259.jpg?1599707796"
                                        },
                                        "art_crop": {
                                            "type": "string",
                                            "example": "https://cards.scryfall.io/art_crop/front/1/c/1cc9e7cb-d4f4-4f06-b232-f91eb39fe1b3.jpg?1734853541"
                                        },
                                        "created_at": {
                                            "type": "string",
                                            "format": "date-time",
                                            "example": "2026-03-11T22:50:26.000000Z"
                                        },
                                        "updated_at": {
                                            "type": "string",
                                            "format": "date-time",
                                            "example": "2026-03-11T22:50:26.000000Z"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The name field is required."
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
