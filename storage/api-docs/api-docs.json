                "operationId": "569f3a6f9ad00bc3bd45dbc7fe1cc3d5",
                "parameters": [
                    {
                        "name": "query",
                        "in": "query",
                        "description": "Search query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "sol ring"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Card results"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Cards",
            "description": "Cards"
        }
    ]
