{
    "openapi": "3.0.0",
    "info": {
        "title": "Commander Deck Master API",
        "description": "API for building and analyzing Commander decks for Magic: The Gathering",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000/api",
            "description": "Local API server"
        }
    ],
    "paths": {
        "/api/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Log in user",
                "operationId": "c1b666be9b4b6b7c1fcb1d33d8f296ef",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful authentication",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "access_token": {
                                            "type": "string",
                                            "example": "QH0mvRZiTfOAds5Zy6B8ngJLZRfzk20nqEhoijgMe6f98fc1"
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "user": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "Admin"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "admin@maus.com"
                                                },
                                                "email_verified_at": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "example": null,
                                                    "nullable": true
                                                },
                                                "created_at": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "example": "2026-03-17T18:31:35.000000Z"
                                                },
                                                "updated_at": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "example": "2026-03-17T18:31:35.000000Z"
                                                },
                                                "two_factor_secret": {
                                                    "type": "string",
                                                    "example": null,
                                                    "nullable": true
                                                },
                                                "two_factor_recovery_codes": {
                                                    "type": "string",
                                                    "example": null,
                                                    "nullable": true
                                                },
                                                "two_factor_confirmed_at": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "example": null,
                                                    "nullable": true
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity"
                    }
                },
                "security": []
            }
        },
        "/cards/search": {
            "get": {
                "tags": [
                    "Cards"
                ],
                "summary": "Search cards",
                "description": "Search cards using the Scryfall API",
                "operationId": "32fa56a962cd66c2fc878e3b5b3c44e8",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Search query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "sol ring"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Card results"
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The q is required."
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/cards/prints": {
            "get": {
                "tags": [
                    "Cards"
                ],
                "summary": "Get card print variations",
                "description": "Get cards print variations using the Scryfall API",
                "operationId": "d90f9a814708cccaf86ba2adda3e9a54",
                "parameters": [
                    {
                        "name": "oracle_id",
                        "in": "query",
                        "description": "Oracle ID for the card on Scryfall",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "b828ba28-e98d-498b-9ab4-d4aa7143e407"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Prints urls"
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The oracle_id field is required."
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/cards/autocomplete": {
            "get": {
                "tags": [
                    "Cards"
                ],
                "summary": "Autocomplete for cards search inputs",
                "description": "Search cards using the Scryfall API autocomplete endpoint",
                "operationId": "5e1123419fc9ec0261b57c08477f2abe",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Search query",
                        "required": true,
                        "schema": {
                            "type": "string",
